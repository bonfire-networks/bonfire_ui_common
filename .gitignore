# The directories Mix/etc will write compiled artifacts to.
/_build/
.cache
.hex
.mix
assets/node_modules
assets/*.log
assets/css/_tailwind_sources.css
priv/cldr
.bonfire-extension-boilerplate
.DS_Store

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
bonfire_*-*.tar

# ignore local mess deps
deps.path

/data

install-state.gz
/assets/static/tauri/test-results
assets/static/tauri/assets/ap_c2s_client
# iOS build staging dir: a pruned copy of the shell (no chat client) used as
# frontendDist for `cargo tauri ios build` — see src-tauri/tauri.ios.conf.json
assets/static/tauri-ios
