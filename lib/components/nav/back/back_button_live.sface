{#if @type == :preview}
  <button
    id="close_preview"
    phx-click="Bonfire.UI.Common.OpenPreviewLive:close"
    :hook={"ClosePreview", from: Bonfire.UI.Common.PreviewContentLive}
    label={l("Go back to the previous page")}
    class="btn btn-sm btn-circle z-50"
  >
    <#Icon iconify="ph:arrow-left" class="w-4 h-4 opacity-70" />
  </button>
{#elseif is_binary(@back)}
  <LinkLive
    to={@back}
    label={l("Go back to the previous page")}
    class="btn btn-sm btn-circle z-50"
    parent_id="back_button"
  >
    <#Icon iconify="ph:arrow-left" class="w-4 h-4 opacity-70" />
  </LinkLive>
{#elseif @back && is_binary(e(@__context__, :last_path, nil))}
  {!-- An in-app previous page exists (per Phoenix's `_live_referer`). Use
       `history.back()` so the browser's forward/back stack handles cycles
       correctly; LV's popstate handler keeps the sticky `PersistentLive`
       alive by routing through the same `replaceMain` as `<.link navigate>`. --}
  <button
    type="button"
    aria-label={l("Go back to the previous page")}
    class="btn btn-sm btn-circle z-50"
    onclick="history.back()"
  >
    <#Icon iconify="ph:arrow-left" class="w-4 h-4 opacity-70" />
  </button>
{#elseif @back}
  <LinkLive
    to="/"
    label={l("Go back to the previous page")}
    class="btn btn-sm btn-circle z-50"
    parent_id="back_button"
  >
    <#Icon iconify="ph:arrow-left" class="w-4 h-4 opacity-70" />
  </LinkLive>
{/if}
