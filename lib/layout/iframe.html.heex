<%= if go = assigns[:go] || e(assigns, :__context__, :go, nil) do %>
  <meta name="session-param-go" content={go} />
<% end %>
<div id="iframe-resize-hook" phx-hook="IframeResize">
  {@inner_content}
  <%!-- Many callers hard-code `reusable_modal_id="persistent_modal"` (originally
       targeting the sticky PersistentLive in the main app layout, which doesn't
       exist inside the iframe). Mount both IDs so either routing target works. --%>
  <.live_component module={Bonfire.UI.Common.ReusableModalLive} id="modal" />
  <.live_component module={Bonfire.UI.Common.ReusableModalLive} id="persistent_modal" />
</div>
<script>
  // Auto-resize the parent iframe when this page's content changes.
  // Uses ResizeObserver (no library needed) and postMessage to the embedder.
  // The IframeResize LiveView hook (bonfire_live.js) also fires on every LV patch.
  (function () {
    function sendHeight() {
      window.parent.postMessage(
        { type: "bonfire:iframe-resize", height: document.body.scrollHeight },
        "*"
      );
    }
    if (typeof ResizeObserver !== "undefined") {
      new ResizeObserver(sendHeight).observe(document.body);
    }
    sendHeight();
  })();
</script>
